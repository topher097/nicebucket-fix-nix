{
  "name": "nicebucket",
  "private": true,
  "version": "0.4.1",
  "type": "module",
  "packageManager": "bun@1.2.20",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "release": "bash scripts/release.sh",
    "build:prod": "NO_STRIP=1 tauri build",
    "build:e2e": "NO_STRIP=1 tauri build --debug --no-bundle",
    "preview": "vite preview",
    "clean": "rm -rf src-tauri/target",
    "tauri": "tauri",
    "test": "vitest run",
    "test:frontend": "vitest",
    "test:e2e": "./scripts/e2e-test.sh",
    "lint": "tsc && eslint .",
    "format:check": "prettier . --check",
    "format": "prettier . --write",
    "wdio": "wdio run wdio.conf.js",
    "postinstall": "bun2nix -o bun.nix"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.1",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query": "^5.99.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-store": "^2.4.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "lucide-react": "^1.8.0",
    "next-themes": "^0.4.6",
    "prettier-plugin-organize-imports": "^4.2.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.12",
    "vitest": "^4.1.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^4.2.3",
    "@tauri-apps/cli": "^2",
    "@testing-library/webdriverio": "^3.2.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@wdio/cli": "^9.27.0",
    "@wdio/globals": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "@wdio/types": "^9.19.2",
    "eslint": "^10.2.1",
    "expect-webdriverio": "^5.6.4",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "standard-version": "^9.5.0",
    "tw-animate-css": "^1.3.7",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "webdriverio": "^9.19.2"
  }
}
